<Window x:Class="WPFUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:WPFUI"
        mc:Ignorable="d"
        Title="Трекер фізичної активності"
        Height="450"
        Width="800">

    <Window.Resources>
        <Style TargetType="Button">
            <Setter Property="Background" Value="LightGray"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="Height" Value="35"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="60"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="200"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock
            Grid.Row="0"
            Grid.ColumnSpan="2"
            Text="Трекер фізичної активності"
            FontSize="24"
            HorizontalAlignment="Center"
            VerticalAlignment="Center"/>

        <StackPanel
            Grid.Row="1"
            Grid.Column="0"
            Margin="10">

            <Button x:Name="btnAdd"
        Content="Додати"
        Command="{Binding AddCommand}"/>

            <Button x:Name="btnEdit"
        Content="Редагувати"
        Command="{Binding EditCommand}"/>

            <Button x:Name="btnDelete"
        Content="Видалити"
        Command="{Binding DeleteCommand}"/>

            <Button x:Name="btnSave"
        Content="Зберегти"
        Command="{Binding SaveCommand}"/>

        </StackPanel>

        <DataGrid
    x:Name="workoutsGrid"
    Grid.Row="1"
    Grid.Column="1"
    Margin="10"
    AutoGenerateColumns="False"
    IsReadOnly="True"
    SelectionMode="Single"
    ItemsSource="{Binding Workouts}"
    SelectedItem="{Binding SelectedWorkout}">

            <DataGrid.Columns>
                <DataGridTextColumn Header="Тип" Binding="{Binding WorkoutType}" Width="*"/>
                <DataGridTextColumn Header="Тривалість" Binding="{Binding DurationMinutes}" Width="*"/>
                <DataGridTextColumn Header="Калорії" Binding="{Binding CaloriesBurned}" Width="*"/>
                <DataGridTextColumn Header="Дата" Binding="{Binding WorkoutDate}" Width="*"/>
            </DataGrid.Columns>

        </DataGrid>
    </Grid>
</Window>
