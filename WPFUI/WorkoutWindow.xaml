<Window x:Class="WPFUI.WorkoutWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Тренування"
        Height="300"
        Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="40"/>
            <RowDefinition Height="60"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="130"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Тип:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtWorkoutType" Grid.Row="0" Grid.Column="1"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Тривалість:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtDuration" Grid.Row="1" Grid.Column="1"/>

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Калорії:" VerticalAlignment="Center"/>
        <TextBox x:Name="txtCalories" Grid.Row="2" Grid.Column="1"/>

        <TextBlock Grid.Row="3" Grid.Column="0" Text="Дата:" VerticalAlignment="Center"/>
        <DatePicker x:Name="dateWorkout" Grid.Row="3" Grid.Column="1"/>

        <StackPanel Grid.Row="4"
                    Grid.ColumnSpan="2"
                    Orientation="Horizontal"
                    HorizontalAlignment="Center"
                    Margin="0,15,0,0">

            <Button x:Name="btnOk" Content="OK" Width="80" Margin="5"/>
            <Button x:Name="btnCancel" Content="Cancel" Width="80" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>
